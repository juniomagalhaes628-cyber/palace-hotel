{
  "name": "Palace Hotel",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20-bullseye",
  "customizations": {
    "vscode": {
      "extensions": [
        "ritwickdey.LiveServer",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ]
    }
  },
  "forwardPorts": [3090, 5500],
  "portsAttributes": {
    "3090": {
      "label": "Palace Hotel Website",
      "onAutoForward": "notify"
    },
    "5500": {
      "label": "Live Server"
    }
  }
}
